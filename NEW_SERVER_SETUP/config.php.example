// Oturum başlat (output buffering içindeyse output üretmemesi için)
if (session_status() === PHP_SESSION_NONE) {
    // Output buffering varsa, session_start öncesi temizle
    if (ob_get_level() > 0) {
        ob_clean();
    }
    @session_start();
}

// Türkiye saat dilimini ayarla
