define('DB_USER', 'u398002296_menu_user'); // cPanel veritabanı kullanıcı adı
define('DB_PASS', 'menuuser**1@K');      // cPanel veritabanı şifresi
define('DB_CHARSET', 'utf8mb4');

// Site Ayarları
define('SITE_URL', 'https://menu.valentinopatisserie.com.tr');  // Canlı domain adresi
